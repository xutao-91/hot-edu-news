{
  "source_id": "edweek",
  "source_name": "Education Week",
  "source_url": "https://www.edweek.org",
  "source_type": "教育新闻媒体",
  "reliability": "高",
  "update_frequency": "每日多次",
  
  "crawl_methods": {
    "primary": "rss",
    "rss_url": "https://www.edweek.org/feeds/rss.xml",
    "fallback": "html_parse",
    "html_url": "https://www.edweek.org/latest-news"
  },
  
  "extract_rules": {
    "date_selectors": [
      "pubDate",
      "published",
      "updated"
    ],
    "title_selector": "title",
    "link_selector": "link",
    "summary_selector": "description",
    "author_selector": "author"
  },
  
  "date_patterns": [
    "%a, %d %b %Y %H:%M:%S %z",
    "%Y-%m-%dT%H:%M:%S",
    "%B %d, %Y"
  ],
  
  "categories": {
    "federal": ["federal", "department of education", "congress"],
    "policy": ["policy", "legislation", " ESSA"],
    "teaching": ["teaching", "teacher", "classroom"],
    "technology": ["technology", "digital", "online learning"],
    "assessment": ["assessment", "testing", "standardized"]
  }
}
